services:
  sentinel-go:
    build: .
    container_name: sentinel-go
    restart: unless-stopped
    ports:
      - "5006:5005"
    environment:
      PORT: "5005"
      AUTHORIZATION: ""
      DEFAULT_MODEL: "gpt-5-5-thinking"
      TEMP_MODE: "false"
      SESSION_TTL_MINUTES: "120"
      TELEGRAM_BOT_TOKEN: ""
      TELEGRAM_CHAT_ID: ""
      # Browser mode: uses real Chromium for auth + Turnstile
      BROWSER_ENABLED: "true"
      BROWSER_HEADLESS: "true"
      # Optional: custom Chrome path (default: auto-detect)
      # BROWSER_CHROME_PATH: "/usr/bin/chromium-browser"
      # Optional: persistent browser profile directory
      # BROWSER_USER_DATA_DIR: "/app/browser-data"
      # Optional: connect to existing Chrome via DevTools Protocol
      # BROWSER_REMOTE_URL: "ws://host.docker.internal:9222"
      BROWSER_TIMEOUT_SEC: "60"
      # Route all API requests through browser (most stealthy, higher latency)
      USE_BROWSER_PROXY: "false"
      DATA_DIR: "/app/data"
    volumes:
      - ./tokens.json:/app/tokens.json
      - ./images:/app/images
      - ./data:/app/data
      # Optional: persist browser profile for faster re-auth
      # - ./browser-data:/app/browser-data
    # Required for Chromium sandbox in Docker
    security_opt:
      - seccomp:unconfined
    shm_size: '2gb'
    healthcheck:
      test: ["CMD", "wget", "-qO-", "http://localhost:5005/health"]
      interval: 30s
      timeout: 5s
      retries: 3

    networks:
      - proxy-net
networks:
  proxy-net:
    external: true
